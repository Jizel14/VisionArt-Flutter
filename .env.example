# VisionArt Flutter Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# API Configuration
# ============================================

# API Base URL for the NestJS backend (PC that runs Nest, port 3000).
#
# Phone HOTSPOT: PC connects Wi‑Fi TO the phone. The PC gets a NEW IP (often 192.168.43.x).
# Run on PC:  ip -brief a  → put that inet here, e.g. http://192.168.43.195:3000
# Do not use the phone’s cellular “10.x” from carrier settings unless that is literally
# the PC’s address on the hotspot interface (it usually is not).
#
# Home Wi‑Fi: use PC’s LAN IP on that router.  Android emulator: http://10.0.2.2:3000
# USB:  adb reverse tcp:3000 tcp:3000  →  http://127.0.0.1:3000
# Nest must listen on 0.0.0.0:3000; open firewall for 3000/tcp on the PC.
#
API_BASE_URL=http://192.168.1.100:3000

# ============================================
# VisionCraft AI Configuration
# ============================================

# VisionCraft API Key for AI image generation
# Get your API key from the VisionCraft Telegram bot: https://t.me/Metimol
# Leave empty if not using AI image generation features
VISIONCRAFT_API_KEY=

# VisionCraft Base URL
VISIONCRAFT_BASE_URL=https://visioncraft.top
