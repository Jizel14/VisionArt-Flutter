<?xml version="1.0" encoding="utf-8"?>
<!-- Allow HTTP to local / LAN API (Nest on :3000). Use HTTPS in production. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
